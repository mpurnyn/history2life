# Amazon Bedrock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
NOVA_API_KEY=

# Firebase
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT=/path/to/firebase-adminsdk.json

# Session
SESSION_SECRET=

# CORS
ALLOWED_ORIGINS=https://your-cloud-run-url.run.app,https://yourdomain.com

# App
APP_ENV=development
APP_PORT=8082
LOG_LEVEL=info
